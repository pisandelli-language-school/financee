# Financee — environment template. Copy to `.env` and fill real values (`.env` is gitignored).

# ── Database (MySQL) ──────────────────────────────────────────────────────────
# Application data lives in your own MySQL environment. Prisma uses this same URL
# for runtime and schema sync commands.
DATABASE_URL="mysql://financee:<password>@<host>:3306/financee"

# ── Supabase Auth (browser client via @nuxtjs/supabase) ───────────────────────
# Anon key is public. Supabase is used for auth/session only; application data lives in MySQL.
NUXT_PUBLIC_SUPABASE_URL="https://<ref>.supabase.co"
NUXT_PUBLIC_SUPABASE_KEY="<anon-key>"

# ── Google Workspace (teacher gating via Directory API) ───────────────────────
# Service Account with domain-wide delegation, impersonating ROOT_USER_EMAIL.
# Reads customSchemas.Custom_Fields.teacher (mirrors ClassTime).
ROOT_USER_EMAIL="admin@yourdomain.com"
GOOGLE_SERVICE_ACCOUNT_JSON='{"type":"service_account", "...": "..."}'

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY="re_..."
